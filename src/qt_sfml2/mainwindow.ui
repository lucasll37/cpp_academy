          <property name="text"><string>Elasticidade</string></property>
         </widget>
        </item>
        <item row="1" column="1">
         <widget class="QSlider" name="sliderRestitution">
          <property name="minimum"><number>0</number></property>
          <property name="maximum"><number>100</number></property>
