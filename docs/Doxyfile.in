PROJECT_NAME           = "@PROJECT_NAME@"
OUTPUT_DIRECTORY       = "@OUTPUT_DIR@"

INPUT                  = @CMAKE_SOURCE_DIR@/src @CMAKE_SOURCE_DIR@/include
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.h *.md

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO

EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO

QUIET                  = YES
WARNINGS               = YES

# Melhorias visuais
HTML_COLORSTYLE_HUE    = 210
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES

# Graphviz
HAVE_DOT               = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
CLASS_DIAGRAMS         = YES
DOT_IMAGE_FORMAT       = svg

# Markdown support
MARKDOWN_SUPPORT       = YES
USE_MDFILE_AS_MAINPAGE = README.md

# Código fonte navegável
SOURCE_BROWSER         = YES
INLINE_SOURCES         = YES

# Namespace e estrutura
FULL_PATH_NAMES        = NO
STRIP_FROM_PATH        = .
